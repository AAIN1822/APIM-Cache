<policies>
  <inbound>
    <base />

    <!-- ===== CACHE LOOKUP ===== -->
    <set-variable name="cacheKey" value="@(context.Request.Body.As&lt;string&gt;(preserveContent: true))" />
    <cache-lookup-value
      key="@((string)context.Variables[&quot;cacheKey&quot;])"
      variable-name="cachedResponse" />
    <choose>
      <when condition="@(context.Variables.ContainsKey(&quot;cachedResponse&quot;))">
        <return-response>
          <set-status code="200" reason="OK" />
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-header name="X-Cache" exists-action="override">
            <value>HIT</value>
          </set-header>
          <set-body>@{
            var cached = (string)context.Variables["cachedResponse"];
            var obj = Newtonsoft.Json.Linq.JObject.Parse(cached);
            obj["source"] = "APIM Cache";
            return obj.ToString();
          }</set-body>
        </return-response>
      </when>
    </choose>

    <!-- ===== BACKEND CYCLING LOGIC =====
      Requests 1-${backend1_switch_at}              → Backend 1
      Requests ${backend1_switch_at+1}-${cycle_size} → Backend 2
      Repeats every ${cycle_size} requests
    -->
    <cache-lookup-value
      key="@(&quot;req-counter-&quot; + context.Request.IpAddress)"
      variable-name="reqCounter" />

    <choose>
      <when condition="@{
        var count = context.Variables.ContainsKey(&quot;reqCounter&quot;)
          ? int.Parse((string)context.Variables[&quot;reqCounter&quot;])
          : 0;
        return (count % ${cycle_size}) >= ${backend1_switch_at};
      }">
        <!-- Switch to Backend 2 -->
        <set-backend-service backend-id="fastapi-backend-2" />
        <set-variable name="activeBackend" value="backend2" />
      </when>
      <otherwise>
        <!-- Use Backend 1 -->
        <set-backend-service backend-id="fastapi-backend-1" />
        <set-variable name="activeBackend" value="backend1" />
      </otherwise>
    </choose>

    <!-- Increment request counter -->
    <cache-lookup-value
      key="@(&quot;req-counter-&quot; + context.Request.IpAddress)"
      variable-name="currentCount" />
    <cache-store-value
      key="@(&quot;req-counter-&quot; + context.Request.IpAddress)"
      value="@{
        var current = context.Variables.ContainsKey(&quot;currentCount&quot;)
          ? int.Parse((string)context.Variables[&quot;currentCount&quot;])
          : 0;
        return (current + 1).ToString();
      }"
      duration="120" />

  </inbound>

  <!-- ===== BACKEND WITH RETRY/FAILOVER ===== -->
  <backend>
    <retry
      condition="@(context.Response.StatusCode == 500 || context.Response.StatusCode == 503)"
      count="1"
      interval="0"
      first-fast-retry="true">
      <choose>
        <when condition="@(context.Response.StatusCode == 500 || context.Response.StatusCode == 503)">
          <set-backend-service backend-id="fastapi-backend-2" />
          <set-variable name="activeBackend" value="backend2" />
        </when>
      </choose>
      <forward-request timeout="${backend_timeout}" buffer-response="true" />
    </retry>
  </backend>

  <!-- ===== OUTBOUND ===== -->
  <outbound>
    <base />

    <!-- Security Headers (OWASP) -->
    <set-header name="X-Frame-Options" exists-action="override">
      <value>DENY</value>
    </set-header>
    <set-header name="X-Content-Type-Options" exists-action="override">
      <value>nosniff</value>
    </set-header>
    <set-header name="X-XSS-Protection" exists-action="override">
      <value>1; mode=block</value>
    </set-header>
    <set-header name="Strict-Transport-Security" exists-action="override">
      <value>max-age=31536000; includeSubDomains</value>
    </set-header>
    <set-header name="Server" exists-action="delete" />

    <!-- Cache Headers -->
    <set-header name="X-Cache" exists-action="override">
      <value>MISS</value>
    </set-header>
    <set-header name="X-Backend-Used" exists-action="override">
      <value>@(context.Request.Url.Host)</value>
    </set-header>
    <set-header name="X-Backend-Active" exists-action="override">
      <value>@((string)context.Variables.GetValueOrDefault("activeBackend","unknown"))</value>
    </set-header>
    <set-header name="X-Request-Count" exists-action="override">
      <value>@{
        var count = context.Variables.ContainsKey("currentCount")
          ? int.Parse((string)context.Variables["currentCount"])
          : 0;
        var cycle = count % ${cycle_size};
        return "total=" + count + " cycle=" + cycle + "/${cycle_size}";
      }</value>
    </set-header>
    <set-header name="Cache-Control" exists-action="override">
      <value>public, max-age=${cache_duration}</value>
    </set-header>

    <!-- Store in APIM Cache -->
    <cache-store-value
      key="@((string)context.Variables[&quot;cacheKey&quot;])"
      value="@(context.Response.Body.As&lt;string&gt;(preserveContent: true))"
      duration="${cache_duration}" />

  </outbound>

  <!-- ===== ERROR HANDLING ===== -->
  <on-error>
    <base />
    <set-header name="Content-Type" exists-action="override">
      <value>application/json</value>
    </set-header>
    <choose>
      <when condition="@(context.Response.StatusCode == 401)">
        <set-body>{"error": "unauthorized", "message": "Invalid or missing subscription key."}</set-body>
      </when>
      <when condition="@(context.Response.StatusCode == 429)">
        <set-body>{"error": "rate_limit_exceeded", "message": "Too many requests. Please try again later."}</set-body>
      </when>
      <when condition="@(context.Response.StatusCode == 413)">
        <set-body>{"error": "request_too_large", "message": "Request body exceeds allowed limit."}</set-body>
      </when>
      <otherwise>
        <set-body>{"error": "internal_error", "message": "An unexpected error occurred."}</set-body>
      </otherwise>
    </choose>
  </on-error>

</policies>
